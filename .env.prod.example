# ============================================
# Credenciais de Produção (Portainer / .env)
# ============================================
# Estas variáveis devem ser configuradas como secrets no Portainer
# ou em um arquivo .env no servidor de produção.
# NUNCA commite valores reais no repositório.

# Banco de Dados (Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth (Better Auth — gere um secret aleatório com: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# URLs públicas
BETTER_AUTH_URL=https://clinicia-api.useia.api.br
API_BASE_URL=https://clinicia-api.useia.api.br
NEXT_PUBLIC_API_URL=https://clinicia-api.useia.api.br
NEXT_PUBLIC_APP_URL=https://clinicia.useia.api.br

# Asaas (Pagamentos)
ASAAS_WEBHOOK_TOKEN=

# OpenAI (OPCIONAL — usado para embeddings RAG)
# OPENAI_API_KEY=sk-xxx
