# Database (local docker: postgresql://postgres:postgres@localhost:5432/crm_clinicas)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (local docker: redis://localhost:6380)
REDIS_URL=redis://localhost:6380

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-this-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Anthropic (agente IA)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (embeddings RAG — opcional, desabilita RAG se não configurado)
OPENAI_API_KEY=sk-xxx

# Asaas (Pagamentos)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# General
NODE_ENV=development
PORT=3001

# Nota: credenciais da Evolution Go (URL, instância, apikey) são configuradas
# por clínica no painel admin — não são variáveis de ambiente globais.
